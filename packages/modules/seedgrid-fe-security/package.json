{
  "name": "@seedgrid/fe-security",
  "version": "2026.7.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeedGrid/seedgrid-fe-components.git"
  },
  "homepage": "https://github.com/SeedGrid/seedgrid-fe-components",
  "bugs": {
    "url": "https://github.com/SeedGrid/seedgrid-fe-components/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./paths": {
      "types": "./dist/paths.d.ts",
      "default": "./dist/paths.js"
    }
  },
  "files": [
    "dist",
    "scaffold"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/emit-module-manifest.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test tests/paths.test.mjs tests/module-manifest.test.mjs tests/permissions.test.mjs"
  },
  "peerDependencies": {
    "@seedgrid/fe-components": "*",
    "@seedgrid/fe-core": "*",
    "next": ">=14",
    "react": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@seedgrid/fe-components": "workspace:*",
    "@seedgrid/fe-core": "workspace:*",
    "next": "15.0.7",
    "react": "19.0.0",
    "@types/react": "^19.0.0"
  }
}
