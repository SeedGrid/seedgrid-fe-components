import * as React from "react";
import { SgInputPhone } from "@seedgrid/fe-components";

export default function App() {
  return (
    <SgInputPhone
      id="eventos"
      label="Com eventos"
      hintText="(11) 99999-0000"
      required
      onChange={(value) => console.log("onChange:", value)}
      onEnter={() => console.log("focus")}
