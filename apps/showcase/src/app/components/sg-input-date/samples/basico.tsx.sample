import * as React from "react";
import { SgInputDate } from "@seedgrid/fe-components";

export default function App() {
  const [basicValue, setBasicValue] = React.useState("");

  return (
    <div className="w-80">
      <SgInputDate id="demo-basic" label="Data" hintText="YYYY-MM-DD" onChange={(value) => setBasicValue(value)} />
      <p className="mt-2 text-xs text-muted-foreground">Valor atual: {basicValue}</p>
    </div>
  );
}
