import * as React from "react";
import { SgInputTextArea } from "@seedgrid/fe-components";

export default function App() {
  return (
    <SgInputTextArea
      id="demo-events"
      label="Com eventos"
      required
      onChange={(value) => console.log("onChange:", value)}
