import * as React from "react";
import { SgPeriodSelector, type ResolvedPeriod } from "@seedgrid/fe-components";

export default function Example() {
  const [period, setPeriod] = React.useState<ResolvedPeriod | null>(null);

  return (
    <div className="w-96 space-y-2">
      <SgPeriodSelector id="ps-basic" label="Periodo" locale="pt-BR" onChange={setPeriod} />
      <pre className="rounded border border-border bg-foreground/5 p-2 text-xs">
        {period
          ? JSON.stringify(
              { preset: period.preset, start: period.startDate, end: period.endDate },
              null,
              2
            )
          : "Nenhum periodo selecionado"}
      </pre>
    </div>
  );
}
